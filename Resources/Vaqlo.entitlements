<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Доступ к микрофону под Hardened Runtime (приложение НЕ в сэндбоксе: нужны
	     Core Audio taps, перечисление процессов, глобальный хоткей, запуск бинарей). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Общий контейнер с виджетом Control Center (статус записи). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.vaqlo</string>
	</array>
</dict>
</plist>
